
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write to their own user document.
    // Admins can read/write any user document.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null;
    }

    // Users can CRUD their own iscribes.
    // Admins can read any iscribe.
    match /iscribes/{iscribeId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
