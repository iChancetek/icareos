
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to create and manage their own profile documents.
    match /users/{userId} {
      // A user can create their own profile document if the document ID matches their user ID
      // and they are providing the necessary initial data.
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // A user can read, update, or delete their own profile document.
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for consultations
    match /consultations/{consultationId} {
      // For now, let's assume any authenticated user can manage consultations.
      // In a production app, you would restrict this to specific roles (e.g., doctors).
      allow read, write: if request.auth != null;
    }

    // Fallback rule: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
