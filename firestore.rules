rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user profile
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      // Admins can read any user profile
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // iScribes: Users can manage their own, Admins can read all
    match /iscribes/{iscribeId} {
      allow create: if request.auth.uid != null;
      allow read, update, delete: if resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Translations: Users can manage their own, Admins can read all
    match /translations/{translationId} {
      allow create: if request.auth.uid != null;
      allow read, update, delete: if resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
